# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth Client ID — get from https://console.cloud.google.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# OpenRouter — get from https://openrouter.ai/keys (free tier available)
VITE_OPENROUTER_KEY=sk-or-your-key
VITE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Hugging Face — get from https://huggingface.co/settings/tokens
VITE_HF_TOKEN=hf_your-token

# App
VITE_APP_URL=http://localhost:5173
